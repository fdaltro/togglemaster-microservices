# Estágio 1: Builder (Compilação)
FROM golang:1.21-alpine AS builder
WORKDIR /app

# 1. Cache de dependências eficiente.
COPY go.mod go.su[m] ./
RUN go mod download

# 2. Copia o código e compila o binário estático
COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -o auth-service .

# Estágio 2: Final (Runtime Seguro)
FROM alpine:3.18

# 3. Instala certificados (necessário para chamadas HTTPS) 
# e cria o usuário não-privilegiado
RUN apk --no-cache add ca-certificates && adduser -D appuser

# 4. Define uma pasta de trabalho neutra (evitando /root)
WORKDIR /app

# 5. Copia o binário e define o dono como o novo usuário
COPY --from=builder /app/auth-service .
RUN chown appuser:appuser auth-service

# 6. A correção do Semgrep: Muda para o usuário comum
USER appuser

# Porta de serviço
EXPOSE 8001

# Execução direta do binário
CMD ["./auth-service"]